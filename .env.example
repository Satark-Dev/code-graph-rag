# NOTE: Strict env mode is enabled.
# Every key in this file must exist in your .env.
# Empty values are allowed only for optional fields (they will be treated as None).

# --- Model Provider Configuration ---
# OpenAI only
ORCHESTRATOR_PROVIDER=openai
ORCHESTRATOR_MODEL=gpt-5.4-nano
ORCHESTRATOR_API_KEY=your-openai-api-key
ORCHESTRATOR_ENDPOINT=
ORCHESTRATOR_PROJECT_ID=
ORCHESTRATOR_REGION=us-east-1
ORCHESTRATOR_PROVIDER_TYPE=
ORCHESTRATOR_THINKING_BUDGET=
ORCHESTRATOR_SERVICE_ACCOUNT_FILE=

CYPHER_PROVIDER=openai
CYPHER_MODEL=gpt-5.4-nano
CYPHER_API_KEY=your-openai-api-key
CYPHER_ENDPOINT=
CYPHER_PROJECT_ID=
CYPHER_REGION=us-east-1
CYPHER_PROVIDER_TYPE=
CYPHER_THINKING_BUDGET=
CYPHER_SERVICE_ACCOUNT_FILE=

# Ollama base URL (required even if not used)
OLLAMA_BASE_URL=http://localhost:11434
BACKEND_API_BASE_URL=http://localhost:8000

# --- Memgraph Settings ---
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_HTTP_PORT=7444
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=
LAB_PORT=3000
MEMGRAPH_BATCH_SIZE=1000

# --- Repository Settings ---
TARGET_REPO_PATH=.

# --- Agent Settings ---
AGENT_RETRIES=3
ORCHESTRATOR_OUTPUT_RETRIES=100

# --- Chat Orchestration (timeouts / schema retries) ---
CHAT_EVIDENCE_TIMEOUT_SECONDS=120
CHAT_SCORING_TIMEOUT_SECONDS=90
CHAT_REMEDIATION_TIMEOUT_SECONDS=90
CHAT_SCHEMA_RETRY_ATTEMPTS=2

# --- Strict Env Mode ---
# If true, config loader enforces that all keys in .env.example exist in .env.
CGR_STRICT_ENV=true

# --- Shell Command Policy ---
SHELL_COMMAND_TIMEOUT=30
SHELL_COMMAND_REPEAT_LIMIT=3
SHELL_COMMAND_REPEAT_WINDOW_SECONDS=30
SHELL_COMMAND_ALLOWLIST=["ls","rg","cat","git","echo","pwd","pytest","mypy","ruff","uv","find","pre-commit","rm","cp","mv","mkdir","rmdir","wc","head","tail","sort","uniq","cut","tr","xargs","awk","sed","tee"]
SHELL_READ_ONLY_COMMANDS=["ls","cat","find","pwd","rg","echo","wc","head","tail","sort","uniq","cut","tr"]
SHELL_SAFE_GIT_SUBCOMMANDS=["status","log","diff","show","ls-files","remote","config","branch"]

# --- Postgres (Core DB → user_org → region → org DB) ---
# Core DB: org_id → region only. Org DBs: tenant data (embeddings, tool logs, etc.).
CORE_DB_HOST=localhost
CORE_DB_PORT=5432
CORE_DB_USER=postgres
CORE_DB_PASSWORD=your-core-db-password
CORE_DB_NAME=satark_core_db
CORE_DB_SSL=false
ORG_DB_HOST_1=localhost
ORG_DB_PORT_1=5433
ORG_DB_USER_1=postgres
ORG_DB_PASSWORD_1=your-org-db-1-password
ORG_DB_NAME_1=satark_org_db_1
ORG_DB_SSL_1=false
ORG_DB_HOST_2=localhost
ORG_DB_PORT_2=5433
ORG_DB_USER_2=postgres
ORG_DB_PASSWORD_2=your-org-db-2-password
ORG_DB_NAME_2=satark_org_db_2
ORG_DB_SSL_2=false
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT=60
DB_CONNECT_TIMEOUT=30

# --- Embedding table (pgvector schema; physical DB host comes from org routing above) ---
PGVECTOR_TABLE_NAME=cgr_code_embeddings
PGVECTOR_DIM=768
PGVECTOR_TOP_K=10
PGVECTOR_UPSERT_RETRIES=3
PGVECTOR_RETRY_BASE_DELAY=0.5
PGVECTOR_BATCH_SIZE=500

# --- Embeddings ---
EMBEDDING_BATCH_SIZE=128
EMBEDDING_MAX_LENGTH=512
EMBEDDING_PROGRESS_INTERVAL=50
SEMANTIC_SEARCH_ENABLED=true
SEMANTIC_SEARCH_EMPTY_COOLDOWN_SECONDS=30
SEMANTIC_SEARCH_REPEAT_COOLDOWN_SECONDS=5
SEMANTIC_RERANK_ENABLED=true
SEMANTIC_RERANK_CANDIDATES=20
SEMANTIC_RERANK_PROVIDER=deepinfra
DEEPINFRA_API_KEY=your-deepinfra-token
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/inference
DEEPINFRA_RERANK_MODEL=Qwen/Qwen3-Reranker-4B
DEEPINFRA_TIMEOUT_SECONDS=30
DEEPINFRA_MAX_RETRIES=2
SERVICE_CACHE_MAX_ENTRIES=8

# --- Source Cache (low-RAM safe defaults) ---
SOURCE_CACHE_MAX_ENTRIES=512
SOURCE_CACHE_MAX_MEMORY_MB=256

# --- AST Cache ---
CACHE_MAX_ENTRIES=1000
CACHE_MAX_MEMORY_MB=500
CACHE_EVICTION_DIVISOR=10
CACHE_MEMORY_THRESHOLD_RATIO=0.8

# --- Flush / Ingestion ---
FLUSH_THREAD_POOL_SIZE=16
FILE_FLUSH_INTERVAL=500

# --- Query Limits ---
QUERY_RESULT_MAX_TOKENS=16000
QUERY_RESULT_ROW_CAP=500

# --- Health / Misc ---
OLLAMA_HEALTH_TIMEOUT=5.0
CGR_QUIET=true

# --- MCP Server ---
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080
MCP_HTTP_ENDPOINT_PATH=/mcp
HF_TOKEN=your-hf-token
MAX_FILE_READ_CHARS=20000
MAX_DIR_LIST_ENTRIES=500

# --- Kafka (async chat jobs; stage-separated pipeline) ---
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_EVIDENCE_JOBS_TOPIC=ai.cgr.evidence
KAFKA_EVIDENCE_CONSUMER_GROUP_ID=cgr-evidence-jobs
KAFKA_EVIDENCE_MAX_CONCURRENCY=4
KAFKA_EVIDENCE_AUTO_OFFSET_RESET=latest
KAFKA_EVIDENCE_FETCH_MAX_WAIT_MS=500
KAFKA_EVIDENCE_SESSION_TIMEOUT_MS=30000
KAFKA_EVIDENCE_RECONNECT_MAX_SECONDS=60
KAFKA_EVIDENCE_RECONNECT_BACKOFF_INITIAL=1
KAFKA_EVIDENCE_TOPIC_NUM_PARTITIONS=3
KAFKA_EVIDENCE_TOPIC_REPLICATION_FACTOR=1

KAFKA_SCORING_JOBS_TOPIC=ai.cgr.score
KAFKA_SCORING_CONSUMER_GROUP_ID=cgr-scoring-jobs
KAFKA_SCORING_MAX_CONCURRENCY=4
KAFKA_SCORING_AUTO_OFFSET_RESET=latest
KAFKA_SCORING_FETCH_MAX_WAIT_MS=500
KAFKA_SCORING_SESSION_TIMEOUT_MS=30000
KAFKA_SCORING_RECONNECT_MAX_SECONDS=60
KAFKA_SCORING_RECONNECT_BACKOFF_INITIAL=1
KAFKA_SCORING_TOPIC_NUM_PARTITIONS=3
KAFKA_SCORING_TOPIC_REPLICATION_FACTOR=1

KAFKA_REMEDIATION_JOBS_TOPIC=ai.cgr.remediation
KAFKA_REMEDIATION_CONSUMER_GROUP_ID=cgr-remediation-jobs
KAFKA_REMEDIATION_MAX_CONCURRENCY=4
KAFKA_REMEDIATION_AUTO_OFFSET_RESET=latest
KAFKA_REMEDIATION_FETCH_MAX_WAIT_MS=500
KAFKA_REMEDIATION_SESSION_TIMEOUT_MS=30000
KAFKA_REMEDIATION_RECONNECT_MAX_SECONDS=60
KAFKA_REMEDIATION_RECONNECT_BACKOFF_INITIAL=1
KAFKA_REMEDIATION_TOPIC_NUM_PARTITIONS=3
KAFKA_REMEDIATION_TOPIC_REPLICATION_FACTOR=1

# --- Kafka (async index jobs; same GraphUpdater as /api/index) ---
KAFKA_INDEX_JOBS_TOPIC=ai.cgr.index
KAFKA_INDEX_CONSUMER_GROUP_ID=cgr-index-jobs
KAFKA_INDEX_MAX_CONCURRENCY=2
KAFKA_INDEX_AUTO_OFFSET_RESET=latest
KAFKA_INDEX_SHUTDOWN_GRACE_SECONDS=30
KAFKA_INDEX_FETCH_MAX_WAIT_MS=500
KAFKA_INDEX_SESSION_TIMEOUT_MS=30000
KAFKA_INDEX_RECONNECT_MAX_SECONDS=60
KAFKA_INDEX_RECONNECT_BACKOFF_INITIAL=1
KAFKA_INDEX_TOPIC_NUM_PARTITIONS=1
KAFKA_INDEX_TOPIC_REPLICATION_FACTOR=1
